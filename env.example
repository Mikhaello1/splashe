# Скопируйте этот файл в .env и заполните значения.
# .env НЕ коммитится в репозиторий (см. .gitignore).

# Токен бота от @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# Telegram ID админов через запятую. Только они управляют ботом.
# Свой ID можно узнать у @userinfobot.
ADMIN_IDS=111111111,222222222

# ID форум-супергруппы, куда бот шлёт алерты (обычно начинается с -100).
# Бот должен быть добавлен в группу как администратор.
ALERT_CHAT_ID=-1001234567890

# message_thread_id топиков внутри группы — по одному на биржу.
# Как узнать: откройте топик в веб-Telegram, число в конце ссылки и есть thread_id.
TOPIC_MEXC=2
TOPIC_KUCOIN=3
TOPIC_GATE=4
TOPIC_BITGET=5
